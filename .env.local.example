# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (optional)
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SiliconFlow API (existing)
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Pro/zai-org/GLM-5
# Image generation models.
# Use a comma-separated fallback list of image models that are actually enabled in your SiliconFlow account.
SILICONFLOW_IMAGE_MODELS=

# OpenRouter (preferred if configured)
# When OPENROUTER_API_KEY is set, chat-build and compile-spec will use OpenRouter first.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_NAME=CreateAnySite

# Hosted preview / build queue
# Public base URL for generated site previews. In production, point this at your Nginx /p prefix.
PREVIEW_BASE_URL=http://127.0.0.1/p

# Filesystem directory that receives published static preview files.
# Nginx should serve this directory directly for /p/<siteId>.
PREVIEW_PUBLISH_DIR=/srv/www/create-any-site/previews

# Build execution mode:
# 0 = do not run builds inside the web process (recommended for production)
# 1 = allow inline execution inside the Next.js process (handy for local dev)
BUILD_INLINE_JOBS=0

# Worker polling interval in milliseconds
BUILD_WORKER_POLL_MS=2000

# Build throughput / dependency strategy
# Keep shared node_modules off for stability. Use a warmed runtime base instead.
USE_SHARED_NODE_MODULES=0

# Max number of concurrent builds across the current process / SQLite state machine.
BUILD_MAX_CONCURRENCY=2

# Optional cache directory for preinstalled runtime dependencies.
RUNTIME_BASE_DIR=
